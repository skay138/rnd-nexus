# LLM
OLLAMA_BASE_URL=http://localhost:11434
RND_MODEL=qwen2.5:32b   # 최초 기동 시 모든 역할의 시드값 — 이후엔 /settings 에서 역할별 관리

# Agent 제어
RND_MAX_ITERATIONS=3
RND_LOG_LEVEL=INFO

# Redis (LangGraph CheckpointSaver)
REDIS_URL=redis://localhost:6379

# MariaDB (MCP 데이터 소스)
# 설정하지 않으면 data/fixtures/*.json 인메모리 fallback
# MARIADB_URL=mysql+pymysql://rnd:rnd_password@localhost:3306/rnd_nexus

# MCP Server URL (ai-server가 연결할 주소)
MCP_SERVER_URL=http://localhost:8000/sse

# 인메모리 Fixtures 경로 (mcp-server용, Docker에서는 자동 설정)
# 로컬 개발 시: 리포 루트에서 실행하면 자동 탐색, 명시적 지정도 가능
# FIXTURES_DIR=data/fixtures

# Milvus (벡터 검색) — 설정하지 않으면 비활성화
# MILVUS_HOST=localhost
# MILVUS_PORT=19530

# Neo4j (그래프 탐색) — 설정하지 않으면 비활성화
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=rnd_password

# AI Server Web API
# API_HOST=0.0.0.0
# API_PORT=8080
